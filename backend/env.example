# ===========================================
# FiveOps Backend - Environment Variables
# ===========================================
# Copy this file to .env and fill in your values

# Server Port
PORT=3050

# ===========================================
# ClickHouse
# ===========================================
CLICKHOUSE_URL=http://localhost:8123
CLICKHOUSE_USERNAME=default
CLICKHOUSE_PASSWORD=
CLICKHOUSE_DATABASE=fiveops
CLICKHOUSE_LOGS_TABLE=logs
CLICKHOUSE_REQUEST_TIMEOUT_MS=30000

# Days to retain log rows. Applied as a TTL on the logs table at first
# bootstrap. Changing this after the table exists requires a manual
# `ALTER TABLE fiveops.logs MODIFY TTL toDateTime(timestamp) + INTERVAL <N> DAY`.
LOG_RETENTION_DAYS=90

# ===========================================
# ClickHouse quick start
# ===========================================
# Docker (single node):
#   docker run -d --name fiveops-ch \
#     -p 8123:8123 -p 9000:9000 \
#     -v fiveops-ch-data:/var/lib/clickhouse \
#     clickhouse/clickhouse-server
#
# Native install: https://clickhouse.com/docs/en/install
# The HTTP interface defaults to port 8123.
# ===========================================
